{
    "name": "rawphp/warp",
    "description": "Warm-worker test engine for Laravel + Pest — boots the app once per process and hands each test a sandboxed clone",
    "type": "library",
    "license": "MIT",
    "keywords": ["laravel", "pest", "testing", "performance", "phpunit"],
    "authors": [
        {
            "name": "Tom Kaczocha"
        }
    ],
    "homepage": "https://github.com/rawphp/warp",
    "support": {
        "source": "https://github.com/rawphp/warp"
    },
    "bin": [
        "bin/warp"
    ],
    "require": {
        "php": "^8.4",
        "phpunit/phpunit": "^11.1 || ^12.0"
    },
    "autoload": {
        "psr-4": {
            "RawPHP\\Warp\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "RawPHP\\Warp\\Tests\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "stable",
    "require-dev": {
        "orchestra/testbench": "^11.1",
        "pestphp/pest": "^4.7",
        "laravel/pint": "^1.29"
    },
    "scripts": {
        "test": "pest",
        "lint": "pint --test",
        "format": "pint"
    }
}
